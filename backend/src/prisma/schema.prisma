
generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}


enum AcquisitionPath {
    MICROPURCHASE
    GSA
    OPEN_MARKET
    SUBCONTRACTING
}

enum InboxStatus {
    NEW
    IN_REVIEW
    QUALIFIED
    DISMISSED
    CONTACTED
    CLOSED
}

enum IndustryDayStatus {
    OPEN
    NOT_ATTENDING
    ATTENDING
    ATTENDED
    PAST_EVENT
}

enum SourceSystem {
    SAM
    USASPENDING
    MANUAL
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  uei       String?  @unique
  cageCode  String?
  website   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inboxItems InboxItem[]
  awards     Award[]
  industryDay IndustryDay[]

  @@index([name])
  @@index([cageCode])
}

model Award {
  id               String   @id @default(cuid())
  source           SourceSystem @default(USASPENDING)

  externalAwardId String?  @unique
  awardingAgency  String?
  awardingOffice  String?

  naics           String?
  psc             String?

  obligatedAmount Decimal? @db.Numeric(18,2)
  startDate       DateTime?
  endDate         DateTime?

  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])

  rawPayload      Json

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([startDate])
  @@index([endDate])
  @@index([naics])
  @@index([psc])
}

model InboxItem {
    id String @id @default(cuid())

    source SourceSystem
    acquisitionPath AcquisitionPath

    title String?
    summary String?
    notes String?

    reviewStatus    InboxStatus @default(NEW)
    reviewedBy      String?
    reviewedAt      DateTime?

    organizationId  String?
    organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

    awardId String?
    award Award? @relation(fields: [awardId], references: [id], onDelete: SetNull)

    // may opt out of including in this model
    industryDayId String?
    industryDay IndustryDay? @relation(fields: [industryDayId], references: [id], onDelete: SetNull)

    rawPayload Json

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([reviewStatus])
    @@index([acquisitionPath])
    @@index([createdAt])
}

model IndustryDay {
    id              String          @id @default(cuid())
    source          SourceSystem @default(SAM)

    // Deduplication check
    externalEventId String? @unique
    title String
    summary String?

    location String?
    eventDate DateTime?
    host String?
    
    status          IndustryDayStatus @default(OPEN)

      organizationId  String?
      organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

      rawPayload Json

      createdAt DateTime @default(now())
      updatedAt DateTime @updatedAt

      @@index([eventDate])
      @@index([status])

}

// TODO: finalize opportunity schema
model Opportunity {

}